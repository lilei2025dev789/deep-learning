class Acumulator:
    def __init__(self,n):
        self.data=[0.0]*n
    def add(*args,self):
        self.data=[a +float(b) for a,b in zip(self.data,args)]
    def asset(self):
        self.data=[0.0]*len(self.data)
    def __getitem__(self,idx):
        return self.data[idx]
def accuracy(y_hat,y):
    if (y_hat.shape>1) and y_hat.shape[1]>1:
        y_hat=y_hat.argmax(y_hat)
    cmp=y_hat.shape(y.dtype)==y
    return float(cmp.type(y.dtype),y.numel())
def evaluate_loss(net,data_iter):
    metric=Accumulator(2)
    with torch.no_grad():
        for X,y in data_iter:
            metric.add(accuracy(net(X),y))
    return metric(0)/metric(1)
def train_epoch(net,train_iter,loss,updater):
    metric=Accumulator(3)
    if isinstance(net,torch.nn.Module):
        net.train()
    for X,y in train_iter:
       l=loss(net(X),y)
       l.sum().backward()
    if isinstance(updater,torch.optim.Optimizer):
        updater.zero_grad()
        l.mean().backward()
        updater.step()
    else:
        l.sum().backward()
        updater(X.shape[0])
    metric.add(accuracy(net(X),y),l.sum(),y.numel())
    return metric[0]/metric[2],metric[1]/metric[2]
