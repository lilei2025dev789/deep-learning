import torch
import torchvision
from d2l import torch as d2l
from IPython import display
import torch.nn as nn
batch_size=256
num_inputs,num_hidden,num_outputs=784,256,10
mnist_train=torchvision.datasets.FashionMNIST(root="./data",download=True,train=True,transform=torchvision.transforms.ToTensor())
mnist_test=torchvision.datasets.FashionMNIST(root="./data",download=True,train=False,transform=torchvision.transforms.ToTensor())
train_iter=torch.utils.data.DataLoader(mnist_train,shuffle=True,batch_size=batch_size)
test_iter=torch.utils.data.DataLoader(mnist_test,shuffle=True,batch_size=batch_size)
device=torch.device("cuda" if torch.cuda.is_available() else "cpu")
W1=torch.normal(0,0.01,size=(num_inputs,num_hidden),requires_grad=True,device=device)
b1=torch.zeros(num_hidden,requires_grad=True,device=device)
W2=torch.normal(0,0.01,size=(num_hidden,num_outputs),requires_grad=True,device=device)
b2=torch.zeros(num_outputs,requires_grad=True,device=device)
params=[W1,b1,W2,b2]

def relu(X):
    return torch.max(X,torch.zeros_like(X))

def net(X):
    X=X.reshape(-1,num_inputs)
    H=relu(X@W1+b1)
    return H@W2+b2

loss=nn.CrossEntropyLoss(reduction="none")

def accuracy(y_hat,y):
    if len(y_hat.shape)>1 and y_hat.shape[1]>1:
       y_hat=y_hat.argmax(axis=1)
    cmp=y_hat.type(y.dtype)==y
    return float(cmp.type(y.dtype).sum())

class Accumulator:
    def __init__(self,n):
        self.data=[0.0]*n
    def add(self,*args):
        self.data=[a+float(b) for a,b in zip(self.data,args)]
    def reset(self):
        self.data=[0.0]*len(self.data)
    def __getitem__(self,idx):
        return self.data[idx]             

def train_epoch(net,train_iter,loss,lr,batch_size):
    metric=Accumulator(3)
    for X,y in train_iter:
        X,y=X.to(device),y.to(device)
        y_hat=net(X)
        l=loss(y_hat,y)
        l.sum().backward()
        with torch.no_grad():
          for param in params:
            param-=lr*param.grad/batch_size
            param.grad.zero_()
        metric.add(l.sum(),accuracy(y_hat,y),y.numel())
    return metric[0]/metric[2],metric[1]/metric[2]
def evaluate_accuracy(net,test_iter):
    metric=Accumulator(2) 
    with torch.no_grad():
        for X,y in test_iter:
            X,y=X.to(device),y.to(device)
            metric.add(accuracy(net(X),y),y.numel())
    return metric[0]/metric[1]
num_epochs=10
lr=0.1
for epoch in range(num_epochs):
    train_loss,train_acc=train_epoch(net,train_iter,loss,lr,batch_size)
    test_acc=evaluate_accuracy(net,test_iter)
    
    print(f"epoch {epoch+1} train_loss={train_loss:.3f},train_acc={train_acc:.3f},test_acc={test_acc:.3f}")
